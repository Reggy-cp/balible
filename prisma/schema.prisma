generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(TOURIST)
  wishlistSlugs     String[]  @default([])
  savedHostSlugs    String[]  @default([])
  phone         String?
  nationality   String?
  locale        String?
  bio           String?
  dateOfBirth   DateTime?
  address       String?
  city          String?
  country       String?
  notifSettings      Json?
  resetToken         String?
  resetTokenExpiry   DateTime?
  createdAt          DateTime  @default(now())

  accounts         Account[]
  bookings         Booking[]
  reviews          Review[]
  wishlist         WishlistItem[]
  operator         Operator?
  notifications    Notification[]
  pushSubscriptions PushSubscription[]
  eventBookings    EventBooking[]
  conversations    Conversation[]
  sentMessages     Message[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Operator {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  businessName String
  description  String
  avatar       String?
  phone        String?
  area         String?
  languages    String?
  website      String?
  address      String?
  city         String?
  country      String?
  notifSettings       Json?
  blockedDates        String[]  @default([])
  coverPhoto          String?
  coverPhotoAlt       String?
  galleryImages       String[]  @default([])
  galleryImageAlts    String[]  @default([])
  verified            Boolean  @default(false)
  rating              Float    @default(0)
  totalReviews        Int      @default(0)
  payoutBank          String?
  payoutAccountNumber String?
  payoutAccountName   String?
  instagram           String?
  tiktok              String?
  facebook            String?
  whatsapp            String?
  youtube             String?

  experiences   Experience[]
  events        Event[]
  payouts       Payout[]
  conversations Conversation[]
}


model Experience {
  id             String     @id @default(cuid())
  slug           String     @unique
  operatorId     String
  operator       Operator   @relation(fields: [operatorId], references: [id])
  title          String
  description    String
  category       Category
  area           Area
  price          Int
  duration       String
  level          String
  language       String     @default("English")
  maxGuests      Int
  minGuests      Int        @default(1)
  subcategory    String     @default("")
  images         String[]
  imageAlts      String[]   @default([])
  highlights     String[]
  includes       String[]
  excludes       String[]
  itinerary      Json       @default("[]")
  schedule       Json?
  meetingPoint   String
  latitude       Float
  longitude      Float
  instantConfirm Boolean    @default(false)
  ecoLabel       Boolean    @default(false)
  featured       Boolean    @default(false)
  rating         Float      @default(0)
  totalReviews   Int        @default(0)
  status         Status     @default(ACTIVE)
  createdAt      DateTime   @default(now())

  bookings Booking[]
  reviews  Review[]
}

model Booking {
  id           String        @id @default(cuid())
  bookingRef   String        @unique @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  experienceId String
  experience   Experience    @relation(fields: [experienceId], references: [id])
  date         DateTime
  guests       Int
  totalPrice   Int
  status       BookingStatus @default(PENDING)
  paymentId    String?
  guestName    String
  guestEmail   String
  guestPhone       String?
  time             String?
  notes            String?
  groupRef         String?
  reviewRequested  Boolean       @default(false)
  reminderSent     Boolean       @default(false)
  createdAt        DateTime      @default(now())

  @@index([groupRef])
}

model Review {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id])
  rating       Int
  comment      String
  flagged      Boolean    @default(false)
  hidden       Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

model Payout {
  id          String       @id @default(cuid())
  operatorId  String
  operator    Operator     @relation(fields: [operatorId], references: [id])
  periodStart DateTime
  periodEnd   DateTime
  gross       Int
  commission  Int
  net         Int
  bookings    Int
  status      PayoutStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime     @default(now())

  @@unique([operatorId, periodStart, periodEnd])
}

model WishlistItem {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  experienceId String
  createdAt    DateTime   @default(now())

  @@unique([userId, experienceId])
}

model Event {
  id          String      @id @default(cuid())
  slug        String      @unique
  operatorId  String
  operator    Operator    @relation(fields: [operatorId], references: [id])
  title       String
  description String
  date        DateTime
  location    String
  price       Int
  capacity    Int
  coverImage  String?
  images      String[]    @default([])
  status      EventStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
  bookings    EventBooking[]
}

model EventBooking {
  id         String        @id @default(cuid())
  bookingRef String        @unique @default(cuid())
  userId     String
  user       User          @relation(fields: [userId], references: [id])
  eventId    String
  event      Event         @relation(fields: [eventId], references: [id])
  tickets    Int
  totalPrice Int
  status     BookingStatus @default(PENDING)
  paymentId  String?
  guestName  String
  guestEmail String
  guestPhone String?
  notes      String?
  createdAt  DateTime      @default(now())
}

enum Role {
  TOURIST
  OPERATOR
  ADMIN
}

enum Category {
  WELLNESS_HEALING
  ART_CRAFT
  CULTURE_SPIRITUAL
  CULINARY
  NATURE_OUTDOORS
  WATER_ACTIVITIES
  LOCAL_EXPERTS
  RENTALS
  SERVICE
}

enum Area {
  UBUD
  CANGGU
  KUTA
  SEMINYAK
  ULUWATU
  GIANYAR
  SANUR
  NUSA_DUA
  AMED
  MEDEWI
  JIMBARAN
  KINTAMANI
  SIDEMEN
}

enum Status {
  ACTIVE
  DRAFT
  PAUSED
  PENDING_REVIEW
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PayoutStatus {
  PENDING
  REQUESTED
  PAID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("homepage")
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  actorId   String?
  action    String
  type      String
  entityId  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([type])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("info")
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Conversation {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  operatorId    String
  operator      Operator  @relation(fields: [operatorId], references: [id])
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())

  messages Message[]

  @@unique([userId, operatorId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  read           Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}
