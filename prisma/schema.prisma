generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(TOURIST)
  wishlistSlugs String[]  @default([])
  createdAt     DateTime  @default(now())

  accounts         Account[]
  bookings         Booking[]
  reviews          Review[]
  wishlist         WishlistItem[]
  operator         Operator?
  provider         Provider?
  serviceBookings  ServiceBooking[]
  notifications    Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Operator {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  businessName String
  description  String
  avatar       String?
  verified            Boolean  @default(false)
  rating              Float    @default(0)
  totalReviews        Int      @default(0)
  payoutBank          String?
  payoutAccountNumber String?
  payoutAccountName   String?

  experiences Experience[]
  events      Event[]
  payouts     Payout[]
}

model Experience {
  id             String     @id @default(cuid())
  slug           String     @unique
  operatorId     String
  operator       Operator   @relation(fields: [operatorId], references: [id])
  title          String
  description    String
  category       Category
  area           Area
  price          Int
  duration       String
  level          String
  language       String     @default("English")
  maxGuests      Int
  images         String[]
  highlights     String[]
  includes       String[]
  excludes       String[]
  meetingPoint   String
  latitude       Float
  longitude      Float
  instantConfirm Boolean    @default(false)
  ecoLabel       Boolean    @default(false)
  featured       Boolean    @default(false)
  rating         Float      @default(0)
  totalReviews   Int        @default(0)
  status         Status     @default(ACTIVE)
  createdAt      DateTime   @default(now())

  bookings Booking[]
  reviews  Review[]
}

model Booking {
  id           String        @id @default(cuid())
  bookingRef   String        @unique @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  experienceId String
  experience   Experience    @relation(fields: [experienceId], references: [id])
  date         DateTime
  guests       Int
  totalPrice   Int
  status       BookingStatus @default(PENDING)
  paymentId    String?
  guestName    String
  guestEmail   String
  guestPhone       String?
  time             String?
  reviewRequested  Boolean       @default(false)
  reminderSent     Boolean       @default(false)
  createdAt        DateTime      @default(now())
}

model Review {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  experienceId String
  experience   Experience @relation(fields: [experienceId], references: [id])
  rating       Int
  comment      String
  flagged      Boolean    @default(false)
  hidden       Boolean    @default(false)
  createdAt    DateTime   @default(now())
}

model Payout {
  id          String       @id @default(cuid())
  operatorId  String
  operator    Operator     @relation(fields: [operatorId], references: [id])
  periodStart DateTime
  periodEnd   DateTime
  gross       Int
  commission  Int
  net         Int
  bookings    Int
  status      PayoutStatus @default(PENDING)
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime     @default(now())

  @@unique([operatorId, periodStart, periodEnd])
}

model WishlistItem {
  id           String     @id @default(cuid())
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  experienceId String
  createdAt    DateTime   @default(now())

  @@unique([userId, experienceId])
}

model Provider {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  businessName String
  description  String
  avatar       String?
  verified     Boolean  @default(false)
  rating       Float    @default(0)
  totalReviews Int      @default(0)
  createdAt    DateTime @default(now())

  listings ServiceListing[]
}

model ServiceListing {
  id           String          @id @default(cuid())
  slug         String          @unique
  providerId   String
  provider     Provider        @relation(fields: [providerId], references: [id])
  title        String
  description  String
  category     ServiceCategory
  subcategory  String
  area         Area
  priceType    PriceType
  price        Int
  images       String[]
  highlights   String[]
  includes     String[]
  excludes     String[]
  available    Boolean         @default(true)
  instantConfirm Boolean       @default(false)
  rating       Float           @default(0)
  totalReviews Int             @default(0)
  featured     Boolean         @default(false)
  status       Status          @default(ACTIVE)
  createdAt    DateTime        @default(now())

  bookings ServiceBooking[]
  reviews  ServiceReview[]
}

model ServiceBooking {
  id          String        @id @default(cuid())
  bookingRef  String        @unique @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  listingId   String
  listing     ServiceListing @relation(fields: [listingId], references: [id])
  startDate   DateTime
  endDate     DateTime?
  duration    String?
  guests      Int           @default(1)
  totalPrice  Int
  status      BookingStatus @default(PENDING)
  guestName   String
  guestEmail  String
  guestPhone  String?
  notes       String?
  createdAt   DateTime      @default(now())
}

model ServiceReview {
  id        String         @id @default(cuid())
  userId    String
  listingId String
  listing   ServiceListing @relation(fields: [listingId], references: [id])
  rating    Int
  comment   String
  createdAt DateTime       @default(now())
}

model Event {
  id          String      @id @default(cuid())
  slug        String      @unique
  operatorId  String
  operator    Operator    @relation(fields: [operatorId], references: [id])
  title       String
  description String
  date        DateTime
  location    String
  price       Int
  capacity    Int
  coverImage  String?
  status      EventStatus @default(DRAFT)
  createdAt   DateTime    @default(now())
}

enum Role {
  TOURIST
  OPERATOR
  PROVIDER
  ADMIN
}

enum ServiceCategory {
  WELLNESS_BEAUTY
  PHOTOGRAPHY_CONTENT
  TRANSPORTATION
  FOOD_DINING
  EVENT_WEDDING
  FITNESS_COACHING
  VILLA_SERVICE
  PET_SERVICE
}

enum PriceType {
  HOURLY
  DAILY
  FIXED
}

enum Category {
  WELLNESS
  ART_CRAFT
  CULTURE
  FOOD_DRINK
  NATURE
  ARCHITECTURE
  SURF_WATER
  DIVING
  COOKING
  LOCAL_EXPERTS
  RENTALS
}

enum Area {
  UBUD
  CANGGU
  KUTA
  SEMINYAK
  ULUWATU
  GIANYAR
  SANUR
  NUSA_DUA
  AMED
  MEDEWI
  JIMBARAN
  KINTAMANI
  SIDEMEN
}

enum Status {
  ACTIVE
  DRAFT
  PAUSED
  PENDING_REVIEW
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PayoutStatus {
  PENDING
  REQUESTED
  PAID
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("homepage")
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  type      String   @default("info")
  title     String
  body      String
  href      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}
